# Kramic.sh Backend Environment Variables

# JWT Authentication
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Google OAuth (Get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Database
DATABASE_URL=sqlite:///./kramic.db
# For PostgreSQL: postgresql://user:password@localhost/kramic
# For Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/kramic

# Blockchain (EAS on Base)
EAS_CONTRACT_ADDRESS=0x4200000000000000000000000000000000000021
BASE_RPC_URL=https://mainnet.base.org
PRIVATE_KEY=  # Your wallet private key for signing attestations (optional)

# Liveblocks (Get from https://liveblocks.io/)
LIVEBLOCKS_SECRET_KEY=sk_prod_your_liveblocks_secret_key

# Redis (Optional, for session management)
REDIS_URL=redis://localhost:6379

# Frontend URL
FRONTEND_URL=http://localhost:3000

# OpenAI (for AI features)
OPENAI_API_KEY=sk-proj-your-openai-api-key

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
