# Kramic.sh Frontend Environment Variables

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL (To be deprecated)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth Client ID (Get from https://console.cloud.google.com/)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Liveblocks Public Key (Get from https://liveblocks.io/)
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_prod_your_liveblocks_public_key
